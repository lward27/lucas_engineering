{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "Messages Processed by Outcome",
      "description": "Total messages processed, split by outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(openclaw_message_processed_total[$__rate_interval])) by (openclaw_outcome)",
          "legendFormat": "{{openclaw_outcome}}"
        },
        {
          "expr": "sum(openclaw_message_processed_total) by (openclaw_outcome)",
          "legendFormat": "total {{openclaw_outcome}}",
          "hide": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "showPoints": "auto",
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Agent Run Duration (p50 / p95 / p99)",
      "description": "How long agent runs take end-to-end",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openclaw_run_duration_ms_milliseconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(openclaw_run_duration_ms_milliseconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(openclaw_run_duration_ms_milliseconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "ms"
        }
      }
    },
    {
      "title": "Token Usage by Type",
      "description": "Cumulative tokens used, split by type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (openclaw_token) (openclaw_tokens_total)",
          "legendFormat": "{{openclaw_token}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Context Window Usage",
      "description": "Tokens used vs context window limit per model",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(openclaw_context_tokens_sum{openclaw_context=\"used\"}) by (openclaw_model)",
          "legendFormat": "used — {{openclaw_model}}"
        },
        {
          "expr": "sum(openclaw_context_tokens_sum{openclaw_context=\"limit\"}) by (openclaw_model)",
          "legendFormat": "limit — {{openclaw_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Queue Depth",
      "description": "Message queue depth over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(openclaw_queue_depth_sum)",
          "legendFormat": "queue depth"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Message Processing Duration (p50 / p95)",
      "description": "End-to-end message processing time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(openclaw_message_duration_ms_milliseconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(openclaw_message_duration_ms_milliseconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "ms"
        }
      }
    },
    {
      "title": "Session State Transitions",
      "description": "Session lifecycle events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(increase(openclaw_session_state_total[$__rate_interval])) by (openclaw_state, openclaw_reason)",
          "legendFormat": "{{openclaw_state}} ({{openclaw_reason}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Tool Usage Distribution (from logs)",
      "description": "Which WebSocket methods are called most",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "sum by (method) (count_over_time({app=\"openclaw\"} |= `res` | regexp `res . (?P<method>[a-zA-Z][\\w.]+) (?P<duration>\\d+)ms` [$__range]))",
          "legendFormat": "{{method}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "title": "Request Methods Over Time (from logs)",
      "description": "WebSocket method calls over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "sum by (method) (count_over_time({app=\"openclaw\"} |= `res` | regexp `res . (?P<method>[a-zA-Z][\\w.]+) (?P<duration>\\d+)ms` [$__interval]))",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Recent Logs",
      "description": "OpenClaw log stream",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 42 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "{app=\"openclaw\"}",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"apps-prod\", pod=~\"openclaw.*\", container!=\"\"}",
          "legendFormat": "{{pod}} / {{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"apps-prod\", pod=~\"openclaw.*\", container!=\"\"}[$__rate_interval])",
          "legendFormat": "{{pod}} / {{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "percentunit"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openclaw", "ai", "observability", "custom"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "America/New_York",
  "title": "OpenClaw Custom Overview",
  "uid": "openclaw-custom-overview",
  "version": 2
}
