{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "LLM API Call Rate",
      "description": "Rate of outbound LLM API calls over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_client_request_duration_seconds_count{service_name=\"openclaw\"}[$__rate_interval])) by (http_request_method, url_path)",
          "legendFormat": "{{http_request_method}} {{url_path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps"
        }
      }
    },
    {
      "title": "LLM API Error Rate",
      "description": "Rate of failed LLM API calls (4xx/5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_client_request_duration_seconds_count{service_name=\"openclaw\", http_response_status_code=~\"[45]..\"}[$__rate_interval])) by (http_response_status_code)",
          "legendFormat": "HTTP {{http_response_status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "title": "LLM API Latency (p50 / p95 / p99)",
      "description": "Duration of outbound LLM API calls",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_client_request_duration_seconds_bucket{service_name=\"openclaw\"}[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_client_request_duration_seconds_bucket{service_name=\"openclaw\"}[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_client_request_duration_seconds_bucket{service_name=\"openclaw\"}[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "auto",
            "stacking": { "mode": "none" }
          },
          "unit": "s"
        }
      }
    },
    {
      "title": "Tool Usage Distribution",
      "description": "Which tools OpenClaw uses most frequently (from logs)",
      "type": "piechart",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "sum by (method) (count_over_time({app=\"openclaw\"} | regexp `res ✓ (?P<method>\\S+) \\d+ms` [$__range]))",
          "legendFormat": "{{method}}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["sum"] }
      }
    },
    {
      "title": "Request Methods Over Time",
      "description": "OpenClaw WebSocket method calls over time",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "sum by (method) (count_over_time({app=\"openclaw\"} | regexp `res ✓ (?P<method>\\S+) \\d+ms` [$__interval]))",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 1,
            "stacking": { "mode": "normal" }
          }
        }
      }
    },
    {
      "title": "Token Usage (Prompt vs Completion)",
      "description": "Token burn rate tracking for cost monitoring",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(llm_prompt_tokens_total{service_name=\"openclaw\"}[$__rate_interval]))",
          "legendFormat": "Prompt Tokens/s"
        },
        {
          "expr": "sum(rate(llm_completion_tokens_total{service_name=\"openclaw\"}[$__rate_interval]))",
          "legendFormat": "Completion Tokens/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Recent Logs",
      "description": "OpenClaw log stream — plain text format",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "datasource": { "type": "loki", "uid": "${loki}" },
      "targets": [
        {
          "expr": "{app=\"openclaw\"}",
          "maxLines": 200
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    },
    {
      "title": "Container Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "container_memory_working_set_bytes{namespace=\"apps-prod\", pod=~\"openclaw.*\", container!=\"\"}",
          "legendFormat": "{{pod}} / {{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "bytes"
        }
      }
    },
    {
      "title": "Container CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{namespace=\"apps-prod\", pod=~\"openclaw.*\", container!=\"\"}[$__rate_interval])",
          "legendFormat": "{{pod}} / {{container}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "stacking": { "mode": "none" }
          },
          "unit": "percentunit"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["openclaw", "ai", "observability", "custom"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Loki",
        "multi": false,
        "name": "loki",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "America/New_York",
  "title": "OpenClaw Custom Overview",
  "uid": "openclaw-custom-overview",
  "version": 1
}
